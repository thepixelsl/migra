---
import { Image } from "astro:assets";
import GalleryLightbox from "./GalleryLightbox.astro";

interface GalleryImage {
  image: ImageMetadata;
  alt: string;
  aspect?: "landscape" | "portrait" | "wide" | "natural";
  muted?: boolean;
  eager?: boolean;
}

interface Props {
  columns: GalleryImage[][];
  galleryId: string;
  label: string;
  dialogLabel?: string;
}

const {
  columns,
  galleryId,
  label,
  dialogLabel = `${label} in Vollansicht`,
} = Astro.props;
---

<section class="gallery-image-grid" aria-label={label}>
  {columns.map((column) => (
    <div class="gallery-image-grid__column">
      {column.map((item) => (
        <figure
          class:list={[
            "gallery-image-grid__item",
            `is-${item.aspect ?? "landscape"}`,
            { "is-muted": item.muted },
          ]}
          data-gallery-reveal
        >
          <button
            class="gallery-image-grid__button"
            type="button"
            data-gallery-trigger={galleryId}
            data-full-src={item.image.src}
            data-alt={item.alt}
            aria-label={`Bild in Vollansicht öffnen: ${item.alt}`}
          >
            <Image
              src={item.image}
              alt={item.alt}
              widths={[360, 620, 920, 1200]}
              sizes="(max-width: 700px) 100vw, (max-width: 1100px) 45vw, 31vw"
              loading={item.eager ? "eager" : "lazy"}
              fetchpriority={item.eager ? "high" : "auto"}
              decoding="async"
            />
          </button>
        </figure>
      ))}
    </div>
  ))}
</section>

<GalleryLightbox galleryId={galleryId} dialogLabel={dialogLabel} />

<script is:inline>
  (() => {
    const items = [...document.querySelectorAll("[data-gallery-reveal]")];
    const reveal = (item) => item.classList.add("is-visible");

    if (!items.length) return;
    if (!("IntersectionObserver" in window)) {
      items.forEach(reveal);
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        reveal(entry.target);
        observer.unobserve(entry.target);
      });
    }, {
      rootMargin: "0px 0px -8% 0px",
      threshold: 0.14,
    });

    items.forEach((item) => observer.observe(item));
  })();
</script>

<style>
  .gallery-image-grid {
    --gallery-gap: clamp(32px, 2.65vw, 52px);
    width: min(1756px, calc(100% - clamp(48px, 10.8vw, 214px)));
    margin: clamp(76px, 8vw, 104px) auto 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--gallery-gap);
    align-items: start;
  }

  .gallery-image-grid__column {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: var(--gallery-gap);
  }

  .gallery-image-grid__item {
    margin: 0;
    background: #eee9e3;
    overflow: hidden;
    opacity: 0;
    transform: translateY(18px);
    will-change: opacity, transform;
  }

  .gallery-image-grid__button {
    width: 100%;
    height: 100%;
    display: block;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: inherit;
    cursor: zoom-in;
  }

  .gallery-image-grid__button:focus-visible {
    outline: 2px solid #2f323c;
    outline-offset: 5px;
  }

  .gallery-image-grid__item.is-visible {
    animation: galleryImageReveal 760ms ease forwards;
  }

  .gallery-image-grid__item :global(img) {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 420ms ease, filter 420ms ease;
  }

  .gallery-image-grid__button:hover :global(img),
  .gallery-image-grid__button:focus-visible :global(img) {
    transform: scale(1.018);
    filter: brightness(.92);
  }

  .gallery-image-grid__item.is-landscape {
    aspect-ratio: 3 / 2;
  }

  .gallery-image-grid__item.is-wide {
    aspect-ratio: 4 / 3;
  }

  .gallery-image-grid__item.is-portrait {
    aspect-ratio: 2 / 3;
  }

  .gallery-image-grid__item.is-natural {
    aspect-ratio: auto;
  }

  .gallery-image-grid__item.is-natural :global(img) {
    height: auto;
    object-fit: contain;
  }

  .gallery-image-grid__item.is-muted :global(img) {
    filter: grayscale(1);
  }

  .gallery-image-grid__item.is-muted .gallery-image-grid__button:hover :global(img),
  .gallery-image-grid__item.is-muted .gallery-image-grid__button:focus-visible :global(img) {
    filter: grayscale(1) brightness(.92);
  }

  @keyframes galleryImageReveal {
    from {
      opacity: 0;
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 980px) {
    .gallery-image-grid {
      width: min(100% - 44px, 760px);
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 32px;
    }

    .gallery-image-grid__column {
      display: contents;
    }
  }

  @media (max-width: 620px) {
    .gallery-image-grid {
      width: min(100% - 24px, 460px);
      grid-template-columns: 1fr;
      margin-top: 72px;
      gap: 24px;
    }

    .gallery-image-grid__column {
      display: contents;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-image-grid__item {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .gallery-image-grid__item :global(img) {
      transition: none;
    }
  }
</style>
