---
const whatsappText = encodeURIComponent("Hallo York! Bist Du noch buchbar am:");
const whatsappHref = `https://wa.me/4915161438120?text=${whatsappText}`;
---

<div class="floating-action" data-floating-action>
  <button
    class="floating-action__toggle"
    type="button"
    aria-expanded="false"
    aria-controls="floating-action-menu"
    aria-label="Schnellkontakt öffnen"
    data-floating-action-toggle
  >
    <img
      src="/images/fab/kontakt-icon-128.png"
      alt=""
      width="128"
      height="128"
      decoding="async"
      loading="eager"
      aria-hidden="true"
    >
    <span class="visually-hidden">Schnellkontakt</span>
  </button>

  <nav
    class="floating-action__menu"
    id="floating-action-menu"
    aria-label="Schnellkontakt"
    aria-hidden="true"
    data-floating-action-menu
  >
    <a class="floating-action__item" href="/kontakt/" data-floating-action-link>
      <span class="floating-action__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path fill="currentColor" d="M7 2h2v2h6V2h2v2h2a3 3 0 0 1 3 3v12a3 3 0 0 1-3 3H5a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3h2V2Zm12 8H5v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-9ZM6 6a1 1 0 0 0-1 1v1h14V7a1 1 0 0 0-1-1H6Z"></path>
        </svg>
      </span>
      <span>Termin noch frei?</span>
    </a>

    <a
      class="floating-action__item"
      href={whatsappHref}
      target="_blank"
      rel="noopener"
      aria-label="WhatsApp Chat mit Artbild-Fotografie öffnen"
      data-floating-action-link
    >
      <span class="floating-action__icon" aria-hidden="true">
        <img src="/images/fab/whatsapp-chat.png" alt="" width="30" height="30" loading="lazy" decoding="async">
      </span>
      <span>WhatsApp</span>
    </a>

    <a class="floating-action__item" href="/kontakt/" data-floating-action-link>
      <span class="floating-action__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path fill="currentColor" d="M4 4h16a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-6l-4 4v-4H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm2 4h12v2H6V8Zm0 4h12v2H6v-2Z"></path>
        </svg>
      </span>
      <span>Kontaktformular</span>
    </a>

    <a
      class="floating-action__item"
      href="mailto:info@artbild-fotografie.de?subject=Anfrage%20%C3%BCber%20Website"
      aria-label="E-Mail an Artbild-Fotografie schreiben"
      data-floating-action-link
    >
      <span class="floating-action__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path fill="currentColor" d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 3.5-8 5-8-5V6l8 5 8-5v1.5Z"></path>
        </svg>
      </span>
      <span>E-Mail</span>
    </a>
  </nav>
</div>

<script>
  const floatingActionRoots = document.querySelectorAll("[data-floating-action]");

  floatingActionRoots.forEach((root) => {
    const toggle = root.querySelector("[data-floating-action-toggle]");
    const menu = root.querySelector("[data-floating-action-menu]");
    const links = root.querySelectorAll("[data-floating-action-link]");

    if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;

    const setOpen = (isOpen) => {
      root.classList.toggle("is-open", isOpen);
      toggle.setAttribute("aria-expanded", String(isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Schnellkontakt schließen" : "Schnellkontakt öffnen");
      menu.setAttribute("aria-hidden", String(!isOpen));
      document.body.classList.toggle("has-floating-action-open", isOpen);

      if (isOpen) {
        const firstLink = menu.querySelector("a[href]");
        if (firstLink instanceof HTMLElement) firstLink.focus();
      }
    };

    toggle.addEventListener("click", () => {
      setOpen(toggle.getAttribute("aria-expanded") !== "true");
    });

    links.forEach((link) => link.addEventListener("click", () => setOpen(false)));

    document.addEventListener("click", (event) => {
      if (!(event.target instanceof Node)) return;
      if (!root.contains(event.target)) setOpen(false);
    });

    root.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setOpen(false);
        toggle.focus();
      }
    });
  });
</script>

<style>
  .floating-action {
    --fab-size: 108px;
    position: fixed;
    right: max(8px, env(safe-area-inset-right));
    bottom: max(10px, env(safe-area-inset-bottom));
    z-index: 2800;
    width: var(--fab-size);
    height: var(--fab-size);
    font-family: "Playfair Display", Georgia, serif;
    color: #0d0d0d;
  }

  .floating-action__toggle {
    width: var(--fab-size);
    height: var(--fab-size);
    padding: 0;
    display: grid;
    place-items: center;
    border: 0;
    border-radius: 50%;
    background: transparent;
    cursor: pointer;
    filter: drop-shadow(0 20px 24px rgba(30, 28, 25, .2));
    transition: transform 180ms ease, filter 180ms ease;
  }

  .floating-action__toggle img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .floating-action__toggle:hover,
  .floating-action__toggle:focus-visible {
    transform: translateY(-2px);
    filter: drop-shadow(0 22px 28px rgba(30, 28, 25, .25));
    outline: 2px solid transparent;
  }

  .floating-action__toggle:focus-visible {
    outline: 2px solid #2c739c;
    outline-offset: 3px;
  }

  .floating-action__menu {
    position: absolute;
    right: 8px;
    bottom: calc(var(--fab-size) + 14px);
    width: min(340px, calc(100vw - 46px));
    padding: 12px;
    display: grid;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, .65);
    border-radius: 20px;
    background: rgba(255, 255, 255, .76);
    box-shadow: 0 18px 42px rgba(0, 0, 0, .24), inset 0 1px 0 rgba(255, 255, 255, .38);
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px) scale(.94);
    transform-origin: 100% 100%;
    transition: opacity 180ms ease, transform 180ms ease;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .floating-action.is-open .floating-action__menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .floating-action__item {
    min-height: 64px;
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    border-radius: 12px;
    color: inherit;
    font-size: 22px;
    line-height: 1.2;
    text-decoration: none;
    transition: background 160ms ease, transform 160ms ease;
  }

  .floating-action__item + .floating-action__item {
    border-top: 1px solid rgba(26, 27, 31, .08);
  }

  .floating-action__item:hover,
  .floating-action__item:focus-visible {
    background: rgba(255, 255, 255, .72);
    outline: 2px solid transparent;
    transform: translateX(-2px);
  }

  .floating-action__item:focus-visible {
    outline: 2px solid #2c739c;
    outline-offset: -2px;
  }

  .floating-action__icon {
    flex: 0 0 38px;
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
  }

  .floating-action__icon svg {
    width: 32px;
    height: 32px;
  }

  .floating-action__icon img {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  :global(.has-mobile-navigation-open) .floating-action {
    visibility: hidden;
  }

  @media (min-width: 768px) {
    .floating-action {
      --fab-size: 116px;
      right: max(14px, env(safe-area-inset-right));
      bottom: max(14px, env(safe-area-inset-bottom));
    }

    .floating-action__menu {
      width: 280px;
    }

    .floating-action__item {
      min-height: 54px;
      padding: 13px 14px;
      font-size: 17px;
    }

    .floating-action__icon {
      flex-basis: 32px;
      width: 32px;
      height: 32px;
    }

    .floating-action__icon svg,
    .floating-action__icon img {
      width: 26px;
      height: 26px;
    }
  }

  @media (min-width: 1200px) {
    .floating-action {
      --fab-size: 96px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-action__toggle,
    .floating-action__menu,
    .floating-action__item {
      transition: none;
    }
  }
</style>
