---
import "../styles/global.css";
import FeaturedPortfolioLinks from "../components/FeaturedPortfolioLinks.astro";
import MobileNavigation from "../components/MobileNavigation.astro";

const destinationLinks = [
  { label: "Venedig", href: "https://artbild-fotografie.de/gallery-category/venedig/" },
  { label: "Mallorca", href: "https://artbild-fotografie.de/gallery-category/mallorca/" },
  { label: "Hannover im Herbst", href: "https://artbild-fotografie.de/gallery-category/hannover/" },
  { label: "Paris", href: "https://artbild-fotografie.de/gallery/paris/" },
  { label: "Hamburg", href: "https://artbild-fotografie.de/gallery-category/hamburg-travel/" },
];

const storyCards = [
  {
    title: "Hochzeit von Steffi & Dominik",
    kicker: "Hochzeitsfotografie Hamburg",
    text: "Eine elegante Hochzeit in Hamburg mit authentischen Momenten, Reportagebildern und viel Nähe zum Brautpaar.",
    href: "/gallery/steffi-dominik/",
    linkLabel: "Hochzeit von Steffi & Dominik ansehen",
    image: "/images/wedding-couple-bouquet.jpg",
    width: 360,
    height: 540,
    alt: "Brautpaar bei einer Hochzeitsreportage in Hamburg",
  },
  {
    title: "Paarshooting Mallorca",
    kicker: "Destination Paarshooting",
    text: "Xenia und Simon wurden in der Nähe von Porto Cristo auf Mallorca begleitet, natürlich, ruhig und mit mediterranem Licht.",
    href: "/gallery/paarshooting-mallorca/",
    linkLabel: "Paarshooting Mallorca ansehen",
    image: "/images/wedding-art-1916.jpg",
    width: 360,
    height: 541,
    alt: "Paarshooting mit warmer Abendstimmung",
  },
];

const articleCards = [
  {
    title: "Das perfekte Getting Ready für deine Hochzeit in Hamburg",
    text: "Was ist die beste Location, wer sollte dabei sein und worauf kommt es fotografisch beim Brautstyling wirklich an?",
    href: "/das-perfekte-getting-ready-fuer-deine-hochzeit-in-hamburg/",
    image: "/images/getting-ready-hamburg-hero.jpg",
    width: 924,
    height: 1384,
    alt: "Braut beim Getting Ready in Hamburg",
  },
  {
    title: "Hochzeitsfotograf Hamburg Preise",
    text: "Antworten auf die wichtigsten Fragen zu Festpreisen, enthaltenen Leistungen und planbaren Kosten für Hochzeitsfotos.",
    href: "https://artbild-fotografie.de/hochzeitsfotograf-preise/",
    image: "/images/post-preise.jpg",
    width: 150,
    height: 150,
    alt: "Hochzeitsfotografie Hamburg Preise",
  },
];

const relatedLinks = [
  { label: "Editorial Traumhochzeit in Paris", href: "https://artbild-fotografie.de/gallery/paris/" },
  { label: "Hochzeit im Hotel Atlantic Hamburg", href: "/gallery/traumhochzeit-in-hamburg/" },
  { label: "Lovebirds am Elbstrand", href: "/gallery/lovebirds-am-elbstrand/" },
  { label: "Getting Ready Hamburg", href: "/das-perfekte-getting-ready-fuer-deine-hochzeit-in-hamburg/" },
];

const miniPortfolio = [
  {
    title: "Engagement Shooting Conny & Alex",
    category: "Portfolio",
    href: "https://artbild-fotografie.de/gallery/engagement-shooting-in-hamburg/",
    image: "/images/wedding-lauenbrueck.jpg",
    width: 360,
    height: 539,
    alt: "Engagement Shooting in Norddeutschland",
  },
  {
    title: "Groom Getting Ready Barber House Hamburg",
    category: "Portfolio",
    href: "https://artbild-fotografie.de/gallery/braeutigam-im-barberhouse-hamburg/",
    image: "/images/portrait-riverside.jpg",
    width: 520,
    height: 780,
    alt: "Elegantes Portrait eines Bräutigams in Hamburg",
  },
  {
    title: "Florale Portraits",
    category: "Florals",
    href: "https://artbild-fotografie.de/gallery/floral-art/",
    image: "/images/art_4265-bearbeitet-2_web.jpg",
    width: 1386,
    height: 924,
    alt: "Florales Editorial Portraitshooting",
  },
];

const vendors = [
  {
    name: "Katharina Seidl",
    text: "Botanical Art, Designstudio und florale Gestaltung für moderne Hochzeiten.",
    href: "https://www.instagram.com/katharina.seidl/",
    cta: "Instagram Profil",
  },
  {
    name: "Foboxy",
    text: "Fotobox für Hochzeiten in Hamburg mit Bildern zum Ausdrucken oder als Online-Galerie.",
    href: "https://foboxy.de/",
    cta: "Jetzt reservieren",
  },
  {
    name: "Ella Deck Couture",
    text: "Maßgeschneiderte und individuell angefertigte Modekonzepte für Hochzeiten.",
    href: "https://elladeck.de/",
    cta: "Jetzt ansehen",
  },
  {
    name: "Visagistin Manija Biebow",
    text: "Friseurmeisterin und Dipl.-Visagistin für hochwertiges Brautstyling in Hamburg.",
    href: "https://artbild-fotografie.de/brautstyling-hamburg/",
    cta: "Über Manija Biebow",
  },
];

const homepageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfessionalService",
      "@id": "https://artbild-fotografie.de/#organization",
      name: "Artbild-Fotografie",
      url: "https://artbild-fotografie.de/",
      image: "https://artbild-fotografie.de/images/logo-artbild-black.png",
      email: "info@artbild-fotografie.de",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Rahlstedter Bahnhofstraße 27",
        postalCode: "22143",
        addressLocality: "Hamburg",
        addressRegion: "Hamburg",
        addressCountry: "DE",
      },
      areaServed: [
        { "@type": "City", name: "Hamburg" },
        { "@type": "AdministrativeArea", name: "Norddeutschland" },
        { "@type": "Place", name: "Mallorca" },
        { "@type": "Place", name: "Venedig" },
        { "@type": "Place", name: "Paris" },
      ],
      serviceType: [
        "Hochzeitsfotografie",
        "Hochzeitsreportage",
        "Standesamtliche Trauung",
        "Paarshooting",
        "Getting Ready Fotografie",
      ],
    },
    {
      "@type": "ItemList",
      "@id": "https://artbild-fotografie.de/#home-lower-sections",
      name: "Hochzeitsfotografie Hamburg, Destination Wedding und Empfehlungen",
      itemListElement: [
        ...storyCards.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.title,
          url: item.href,
        })),
        ...articleCards.map((item, index) => ({
          "@type": "ListItem",
          position: storyCards.length + index + 1,
          name: item.title,
          url: item.href.startsWith("http") ? item.href : `https://artbild-fotografie.de${item.href}`,
        })),
      ],
    },
  ],
};
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Hochzeitsfotograf Hamburg. Kreative und emotionale Hochzeitsfotos in Hamburg und europaweit.">
  <meta name="robots" content="follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large">
  <link rel="canonical" href="https://artbild-fotografie.de/">
  <title>Hochzeitsfotograf Hamburg</title>
  <script type="application/ld+json" set:html={JSON.stringify(homepageSchema)}></script>
  <script src="/js/hero-slider.js" defer></script>
</head>
<body id="top">
  <header class="site-header">
    <a class="booking-strip" href="#kontakt">Jetzt für 2026/2027 buchen</a>
    <MobileNavigation />
    <div class="nav-shell">
      <a class="brand" href="#" aria-label="Artbild-Fotografie Startseite">
        <img src="/images/logo-artbild-black.png" width="1200" height="480" alt="Artbild Fotografie Logo">
