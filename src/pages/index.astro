  </header>

  <main>
    <section class="hero-slider hero-slider--desktop" data-hero-slider data-mode="desktop" aria-label="Hero Slider Desktop">
      <div class="hero-slider__viewport">
        <div class="hero-slider__stage">
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/cropped-hochzeitsreportage_hamburg_festpreis-scaled-1.jpg" width="640" height="853" alt="Brautportrait mit Blumenstrauß" decoding="async">
          </figure>
          <figure class="hero-slider__slide is-initial" data-focus-x="72" data-focus-y="98">
            <img src="/images/paris_braut_fotoshooting-17.jpg" width="1068" height="1600" alt="Braut beim Fotoshooting in Paris" loading="eager" fetchpriority="high" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="97" data-focus-y="61">
            <img data-src="/images/paris_braut_fotoshooting-25.jpg" width="1068" height="1600" alt="Lachende Braut vor dem Eiffelturm" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/paris_braut_fotoshooting-16.jpg" width="1068" height="1600" alt="Braut in kurzem Kleid in Paris" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/paris_braut_fotoshooting-31.jpg" width="1068" height="1600" alt="Portrait einer Braut am See" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/art_3822-verbessert-rr-bearbeitet-bearbeitet-scaled-1.jpg" width="924" height="1386" alt="Braut auf einer eleganten Treppe" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/art_4102-verbessert-rr-bearbeitet-scaled-1.jpg" width="924" height="1386" alt="Braut mit Bouquet im Treppenhaus" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/art_4265-bearbeitet-2_web.jpg" width="1386" height="924" alt="Brautjungfer im Schweriner Schlossgarten" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/art_4632.jpg" width="924" height="1386" alt="Brautportrait mit Schleier" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/art_3143-bearbeitet-scaled-2.jpg" width="924" height="1384" alt="Braut mit Schleier" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/getting_ready_hochzeitsfotograf_hamburg2372-scaled-2.jpg" width="924" height="1384" alt="Getting-ready-Moment vor der Hochzeit" decoding="async">
          </figure>
        </div>
      </div>
      <div class="hero-slider__controls" aria-label="Slider Steuerung">
        <button class="hero-slider__button" type="button" data-slider-prev aria-label="Vorheriges Bild">‹</button>
        <button class="hero-slider__button" type="button" data-slider-toggle aria-label="Slider pausieren" aria-pressed="false">Pause</button>
        <button class="hero-slider__button" type="button" data-slider-next aria-label="Nächstes Bild">›</button>
      </div>
    </section>

    <section class="hero-slider hero-slider--mobile" data-hero-slider data-mode="mobile" aria-label="Hero Slider Mobile">
      <div class="hero-slider__viewport">
        <div class="hero-slider__stage">
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/cropped-hochzeitsreportage_hamburg_festpreis-scaled-1.jpg" width="640" height="853" alt="Brautportrait mit Blumenstrauß" decoding="async">
          </figure>
          <figure class="hero-slider__slide is-initial" data-focus-x="97" data-focus-y="99">
            <img src="/images/paris_braut_fotoshooting-17.jpg" width="1068" height="1600" alt="Braut beim Fotoshooting in Paris" loading="eager" fetchpriority="high" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="98" data-focus-y="99">
            <img data-src="/images/paris_braut_fotoshooting-25.jpg" width="1068" height="1600" alt="Lachende Braut vor dem Eiffelturm" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/paris_braut_fotoshooting-16.jpg" width="1068" height="1600" alt="Braut in kurzem Kleid in Paris" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/paris_braut_fotoshooting-31.jpg" width="1068" height="1600" alt="Portrait einer Braut am See" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/art_3822-verbessert-rr-bearbeitet-bearbeitet-scaled-1.jpg" width="924" height="1386" alt="Braut auf einer eleganten Treppe" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/art_4102-verbessert-rr-bearbeitet-scaled-1.jpg" width="924" height="1386" alt="Braut mit Bouquet im Treppenhaus" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/art_4265-bearbeitet-2_web.jpg" width="1386" height="924" alt="Brautjungfer im Schweriner Schlossgarten" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/art_4632.jpg" width="924" height="1386" alt="Brautportrait mit Schleier" decoding="async">
          </figure>
          <figure class="hero-slider__slide" data-focus-x="50" data-focus-y="50">
            <img data-src="/images/art_3143-bearbeitet-scaled-2.jpg" width="924" height="1384" alt="Braut mit Schleier" decoding="async">
          </figure>
