---
const title = "Migration Preview – Artbild Fotografie";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: light;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f6f4ef;
        color: #1f2328;
      }

      body {
        min-height: 100vh;
        margin: 0;
        display: grid;
        place-items: center;
      }

      main {
        width: min(100% - 32px, 720px);
        text-align: center;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 7vw, 4rem);
        font-weight: 500;
        letter-spacing: 0;
        line-height: 1.1;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Migration Preview – Artbild Fotografie</h1>
    </main>
  </body>
</html>
