const galleryColumns = [
  ["img0", "img4", "img8", "img11", "img13", "img16", "img20", "img23", "img26"],
  ["img1", "img5", "img7", "img10", "img14", "img17", "img19", "img21", "img24", "img27"],
  ["img2", "img3", "img6", "img9", "img12", "img15", "img18", "img22", "img25", "img28"],
].map((column) => column.map((id) => galleryImages.find((item) => item.id === id)).filter(Boolean));

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${pageUrl}#article`,
      headline: title,
      name: title,
      description,
      keywords: "Hochzeitsfotos Hamburg",
      author: {
        "@type": "Person",
        name: "York Augustin",
      },
      datePublished: "2025-05-15T16:03:30+02:00",
      dateModified: "2025-06-11T18:26:25+02:00",
      image: {
        "@id": `${pageUrl}#primaryimage`,
      },
      publisher: {
        "@id": `${siteUrl}/#organization`,
      },
      mainEntityOfPage: {
        "@id": `${pageUrl}#webpage`,
      },
      inLanguage: "de",
    },
    {
      "@type": "ImageGallery",
      "@id": `${pageUrl}#gallery`,
      name: heading,
      description,
      image: galleryImages.map((item, index) => ({
        "@type": "ImageObject",
        position: index + 1,
        caption: item.alt,
      })),
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      name: "Artbild Fotografie Hochzeitsfotograf Hamburg",
      legalName: "Artbild-Fotografie",
