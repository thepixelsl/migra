  "@graph": [
    {
      "@type": "Article",
      "@id": `${pageUrl}#article`,
      headline: title,
      name: title,
      description,
      keywords: "Hochzeitsfotos Hamburg",
      author: {
        "@type": "Person",
        name: "York Augustin",
