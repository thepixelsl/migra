      sameAs: [
        "https://www.facebook.com/artbildfotografie/",
        "https://twitter.com/artbild",
        "https://www.instagram.com/artbild/",
      ],
      email: "info@artbild-fotografie.de",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Rahlstedter Bahnhofstraße 27",
        addressLocality: "Rahlstedt",
        addressRegion: "Hamburg",
        postalCode: "22143",
        addressCountry: "Deutschland",
      },
      logo: {
        "@type": "ImageObject",
        "@id": `${siteUrl}/#logo`,
        url: logoUrl,
        contentUrl: logoUrl,
        caption: "Artbild-Fotografie",
        inLanguage: "de",
      },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          item: {
            "@id": siteUrl,
            name: "Startseite",
          },
        },
        {
          "@type": "ListItem",
          position: 2,
          item: {
            "@id": pageUrl,
            name: heading,
          },
        },
      ],
    },
    {
      "@type": "ImageObject",
      "@id": `${pageUrl}#primaryimage`,
      url: ogImage,
      width: "924",
      height: "924",
      caption: "Hochzeitsreportage Hamburg Preise",
      inLanguage: "de",
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: title,
      description,
      datePublished: "2025-05-15T16:03:30+02:00",
      dateModified: "2025-06-11T18:26:25+02:00",
