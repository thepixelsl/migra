  { id: "img9", image: img9, alt: "Hochzeitsfoto einer Braut im Hotelzimmer" },
  { id: "img10", image: img10, alt: "Getting Ready Brautfoto in Hamburg" },
  { id: "img11", image: img11, alt: "Detailaufnahme aus einem Brautshooting in Hamburg" },
  { id: "img12", image: img12, alt: "Brautportrait mit elegantem Kleid in Hamburg" },
  { id: "img13", image: img13, alt: "Hochzeitsfoto einer Braut in ruhigem Licht" },
  { id: "img14", image: img14, alt: "Braut im Hotel beim Fotoshooting in Hamburg" },
  { id: "img15", image: img15, alt: "Klassisches Brautportrait in Hamburg" },
  { id: "img16", image: img16, alt: "Braut vor einer Hochzeit in den Fraser Suites" },
  { id: "img17", image: img17, alt: "Elegantes Hochzeitsdetail in Hamburg" },
  { id: "img18", image: img18, alt: "Brautshooting im Hotel in Hamburg" },
  { id: "img19", image: img19, alt: "Hochzeitsfoto mit Brautkleid in Hamburg" },
  { id: "img20", image: img20, alt: "Brautportrait im Innenraum der Fraser Suites" },
  { id: "img21", image: img21, alt: "Editoriales Hochzeitsfoto einer Braut" },
  { id: "img22", image: img22, alt: "Brautbild mit Tageslicht in Hamburg" },
  { id: "img23", image: img23, alt: "Braut beim Getting Ready in Hamburg" },
  { id: "img24", image: img24, alt: "Stilvolle Hochzeitsfotografie in den Fraser Suites" },
  { id: "img25", image: img25, alt: "Brautportrait im Hotelambiente" },
  { id: "img26", image: img26, alt: "Braut Foto in klassischer Hamburger Location" },
  { id: "img27", image: img27, alt: "Hochzeitsfoto einer Braut im eleganten Innenraum" },
  { id: "img28", image: img28, alt: "Brautshooting als Inspiration für Hochzeitsfotos Hamburg" },
