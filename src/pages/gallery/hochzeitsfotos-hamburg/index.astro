  { id: "img1", image: img1, alt: "Braut in elegantem Kleid beim Getting Ready in Hamburg" },
  { id: "img2", image: img2, alt: "Elegantes Hochzeitsfoto in den Fraser Suites Hamburg" },
  { id: "img3", image: img3, alt: "Braut am Fenster in den Fraser Suites Hamburg" },
  { id: "img4", image: img4, alt: "Brautportrait mit feinem Licht in Hamburg" },
  { id: "img5", image: img5, alt: "Editoriales Brautfoto im Hotel in Hamburg" },
  { id: "img6", image: img6, alt: "Fraser Suites Hamburg Braut Hochzeit" },
  { id: "img7", image: img7, alt: "Brautbild mit klassischer Architektur in Hamburg" },
