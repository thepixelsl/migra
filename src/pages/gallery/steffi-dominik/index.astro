---
import "../../../styles/global.css";
import MobileNavigation from "../../../components/MobileNavigation.astro";
import GalleryImageGrid from "../../../components/GalleryImageGrid.astro";

const imageModules = import.meta.glob(
  "../../../assets/steffi-dominik/*.jpg",
  { eager: true, import: "default" },
) as Record<string, ImageMetadata>;

const siteUrl = "https://artbild-fotografie.de";
const pagePath = "/gallery/steffi-dominik/";
const pageUrl = `${siteUrl}${pagePath}`;
const heading = "Steffi & Dominik";
const title = "Hochzeit von Steffi & Dominik in der Nordheide | Artbild-Fotografie";
const description =
  "Hochzeitsreportage von Steffi und Dominik in Buchholz in der Nordheide: Trauung, Oldtimer, Hofscheune und natürliches Brautpaarshooting.";
const logoUrl = `${siteUrl}/images/logo-artbild-black.png`;

const altByFile: Record<string, string> = {
  "ART1825.jpg": "Grüner Brautkranz hängt beim Getting Ready über einem Spiegel",
  "ART2288.jpg": "Braut Steffi hält ihre beschrifteten Brautschuhe vor der Hochzeit",
  "ART3400-1024x684.jpg": "Geschmückter Mercedes Oldtimer als Hochzeitsauto in der Nordheide",
  "ART2418-1024x684.jpg": "Braut blickt durch die Scheibe des Hochzeitsautos",
  "ART2899.jpg": "Steffi und Dominik küssen sich bei ihrer Hochzeit",
  "ART2950-1024x732.jpg": "Brautpaar beim natürlichen Hochzeitsshooting am See",
  "ART3124.jpg": "Hochzeitsbrauch mit Braut und Bräutigam im Freien",
  "ART3161-1024x732.jpg": "Brautschuhe mit der Aufschrift Ich will",
  "ART3365-1024x684.jpg": "Küssendes Brautpaar auf einer Bank vor einem Fachwerkhaus",
  "ART3705-1024x684.jpg": "Steffi und Dominik sprechen zu ihren Gästen in der Hofscheune",
  "ART3529-2-1024x684.jpg": "Brautpaar vor der historischen Hofscheune in der Nordheide",
  "ART3225.jpg": "Braut Steffi mit ihrem rosa-weißen Brautstrauß",
  "ART3645-1024x684.jpg": "Lachender Bräutigam beim gemeinsamen Baumstammsägen",
  "ART3667-1024x684.jpg": "Lachende Braut nach dem Baumstammsägen",
  "ART2540-1024x684.jpg": "Braut steckt dem Bräutigam bei der Trauung den Ehering an",
  "ART2528-1024x684.jpg": "Bräutigam nimmt den Ehering von einer Holzscheibe",
  "ART3644.jpg": "Bräutigam beim Baumstammsägen nach der Trauung",
  "ART2827-1024x684.jpg": "Braut umarmt einen Hochzeitsgast nach der Trauung",
  "ART3530-2-1024x684.jpg": "Schwarz-Weiß-Portrait des Bräutigams aus Sicht der Braut",
  "ART3574-Bearbeitet-1024x684.jpg": "Braut und Bräutigam blicken sich vor der Hofscheune an",
  "ART3566-2-1024x732.jpg": "Schwarz-Weiß-Portrait von Steffi und Dominik mit Brautstrauß",
  "ART3548.jpg": "Brautportrait mit Blumenstrauß an der Hofscheune",
  "ART3557-Bearbeitet-2-1024x684.jpg": "Inniges Schwarz-Weiß-Portrait des Brautpaares in der Nordheide",
  "ART3390-1024x684.jpg": "Brautstrauß und Blumenarrangement auf der Hochzeitsfeier",
};

const modulesByFile = Object.fromEntries(
  Object.entries(imageModules).map(([path, image]) => [
    path.split("/").pop() ?? path,
    image,
  ]),
) as Record<string, ImageMetadata>;

const galleryImages = Object.entries(altByFile).map(([file, alt], index) => ({
  id: file.replace(/\.jpg$/, ""),
  image: modulesByFile[file],
  alt,
  aspect: "natural" as const,
  eager: index === 0,
}));

const itemsPerColumn = Math.ceil(galleryImages.length / 3);
const galleryColumns = [
  galleryImages.slice(0, itemsPerColumn),
  galleryImages.slice(itemsPerColumn, itemsPerColumn * 2),
  galleryImages.slice(itemsPerColumn * 2),
];

const primaryImage = new URL(galleryImages[0].image.src, siteUrl).href;
const buchholzPlace = {
  "@type": "City",
  "@id": `${pageUrl}#buchholz`,
  name: "Buchholz in der Nordheide",
  address: {
    "@type": "PostalAddress",
    postalCode: "21244",
    addressLocality: "Buchholz in der Nordheide",
    addressRegion: "Niedersachsen",
    addressCountry: "DE",
  },
};

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${pageUrl}#article`,
      headline: heading,
      name: title,
      description,
      keywords: [
        "Hochzeit Buchholz Nordheide",
        "Hochzeitsfotograf Nordheide",
        "Hochzeitsreportage Niedersachsen",
        "Hochzeit Hofscheune",
      ],
      datePublished: "2019-12-20T11:23:54+01:00",
      dateModified: "2026-06-25T08:00:00+02:00",
      author: {
        "@type": "Person",
        name: "York Augustin",
      },
      publisher: {
        "@id": `${siteUrl}/#organization`,
      },
      image: primaryImage,
      mainEntityOfPage: {
        "@id": `${pageUrl}#webpage`,
      },
      contentLocation: {
        "@id": `${pageUrl}#buchholz`,
      },
      inLanguage: "de",
    },
    {
      "@type": "ImageGallery",
      "@id": `${pageUrl}#gallery`,
      name: "Hochzeit von Steffi und Dominik in der Nordheide",
      description,
      contentLocation: {
        "@id": `${pageUrl}#buchholz`,
      },
      image: galleryImages.map((item, index) => ({
        "@type": "ImageObject",
        position: index + 1,
        caption: item.alt,
        contentUrl: new URL(item.image.src, siteUrl).href,
        width: item.image.width,
        height: item.image.height,
      })),
    },
    buchholzPlace,
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#organization`,
      name: "Artbild-Fotografie",
      url: siteUrl,
      email: "info@artbild-fotografie.de",
      logo: {
        "@type": "ImageObject",
        url: logoUrl,
      },
      address: {
        "@type": "PostalAddress",
        streetAddress: "Rahlstedter Bahnhofstraße 27",
        postalCode: "22143",
        addressLocality: "Hamburg",
        addressRegion: "Hamburg",
        addressCountry: "DE",
      },
      areaServed: [
        { "@type": "City", name: "Hamburg" },
        { "@type": "City", name: "Buchholz in der Nordheide" },
        { "@type": "State", name: "Niedersachsen" },
        { "@type": "AdministrativeArea", name: "Norddeutschland" },
      ],
      serviceType: [
        "Hochzeitsfotografie",
        "Hochzeitsreportage",
        "Getting Ready Fotografie",
        "Brautpaarshooting",
      ],
      sameAs: [
        "https://www.instagram.com/artbild/",
        "https://www.facebook.com/artbildfotografie/",
        "https://www.pinterest.de/artbildf/",
      ],
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Startseite",
          item: siteUrl,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Portfolio",
          item: `${siteUrl}/portfolio/`,
        },
        {
          "@type": "ListItem",
          position: 3,
          name: heading,
          item: pageUrl,
        },
      ],
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: title,
      description,
      datePublished: "2019-12-20T11:23:54+01:00",
      dateModified: "2026-06-25T08:00:00+02:00",
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: primaryImage,
        caption: "Steffi und Dominik bei ihrer Hochzeit in der Nordheide",
      },
      breadcrumb: {
        "@id": `${pageUrl}#breadcrumb`,
      },
      inLanguage: "de",
    },
  ],
};
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large">
  <link rel="canonical" href={pageUrl}>
  <meta property="og:locale" content="de_DE">
  <meta property="og:type" content="article">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={pageUrl}>
  <meta property="og:site_name" content="Artbild-Fotografie">
  <meta property="article:published_time" content="2019-12-20T11:23:54+01:00">
  <meta property="article:modified_time" content="2026-06-25T08:00:00+02:00">
  <meta property="og:image" content={primaryImage}>
  <meta property="og:image:width" content={galleryImages[0].image.width}>
  <meta property="og:image:height" content={galleryImages[0].image.height}>
  <meta property="og:image:alt" content={galleryImages[0].alt}>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={primaryImage}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)}></script>
</head>
<body class="gallery-template steffi-gallery-page">
  <header class="gallery-header">
    <MobileNavigation />
    <nav class="gallery-nav" aria-label="Hauptnavigation">
      <ul class="gallery-nav__group">
        <li><a href="/">Start</a></li>
        <li><a href="/portfolio/">Portfolio</a></li>
        <li><a href="/kontakt/">Kontakt</a></li>
      </ul>
      <a class="gallery-logo" href="/" aria-label="Artbild-Fotografie Startseite">
        <img src="/images/logo-artbild-black.png" width="1200" height="480" alt="Artbild Fotografie">
      </a>
      <ul class="gallery-nav__group">
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/about/">Über mich</a></li>
        <li><a href="/newsletter/">Newsletter</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <article class="steffi-gallery">
      <header class="steffi-hero">
        <p class="steffi-hero__script" aria-hidden="true">Steffi & Dominik</p>
        <p class="steffi-hero__kicker">Hochzeitsreportage · Buchholz in der Nordheide</p>
        <h1>{heading}</h1>
        <p>
          Eine persönliche Hochzeit zwischen Oldtimer, See und historischer
          Hofscheune im Süden von Hamburg.
        </p>
      </header>

      <section class="steffi-story" aria-labelledby="steffi-story-title">
        <div class="steffi-story__heading">
          <p>Hochzeit in der Nordheide</p>
          <h2 id="steffi-story-title">Ein Hochzeitstag mit echten Momenten und norddeutschem Charakter</h2>
        </div>
        <div class="steffi-story__copy">
          <div>
            <h3>Details & Ankunft</h3>
            <p>
              Brautkranz, beschriftete Schuhe und ein liebevoll geschmückter
              Mercedes erzählen den Auftakt. Schon auf der Fahrt entstehen
              stille, persönliche Bilder der Braut.
            </p>
          </div>
          <div>
            <h3>Trauung & Traditionen</h3>
            <p>
              Ringtausch, Umarmungen und das gemeinsame Baumstammsägen halten
              die großen und kleinen Momente rund um das Ja-Wort als lebendige
              Reportage fest.
            </p>
          </div>
          <div>
            <h3>See & Hofscheune</h3>
            <p>
              Das Paarshooting führt Steffi und Dominik ans Wasser und vor die
              rustikale Hofscheune. Die Umgebung gibt den Bildern Wärme, Ruhe
              und einen unverwechselbaren norddeutschen Rahmen.
            </p>
          </div>
        </div>
      </section>

      <GalleryImageGrid
        columns={galleryColumns}
        galleryId="steffi-dominik"
        label="Hochzeitsreportage von Steffi und Dominik in Buchholz in der Nordheide"
        dialogLabel="Hochzeit von Steffi und Dominik in Vollansicht"
      />

      <aside class="steffi-meta" aria-label="Galeriethemen">
        <span>Themen:</span>
        <a href="/gallery-tag/nordheide/">Nordheide</a>
        <a href="/gallery-tag/niedersachsen/">Niedersachsen</a>
        <a href="/gallery-tag/hamburg/">Hamburg</a>
        <a href="/gallery-tag/hochzeit/">Hochzeit</a>
      </aside>

      <section class="steffi-service" aria-labelledby="steffi-service-title">
        <div>
          <p class="steffi-service__kicker">Preise transparent vergleichen</p>
          <h2 id="steffi-service-title">Hochzeitsfotografie als planbarer Festpreis</h2>
        </div>
        <div>
          <p>
            Ob Standesamt, freie Trauung oder eine Feier auf dem Land: Dauer,
            Leistungen und Bildbearbeitung werden vor der Hochzeit klar und
            nachvollziehbar vereinbart.
          </p>
          <p>
            So könnt Ihr Pakete und enthaltene Leistungen in Ruhe vergleichen,
            ohne nach der Hochzeit von versteckten Zusatzkosten überrascht zu
            werden.
          </p>
          <div class="steffi-service__actions">
            <a href="/hochzeitsfotograf-preise/">Preise & Pakete ansehen</a>
            <a class="is-primary" href="/kontakt/">Hochzeit anfragen</a>
          </div>
        </div>
      </section>

      <nav class="steffi-related" aria-label="Weitere Hochzeitsreportagen">
        <a href="/gallery/hochzeitsfotograf-niedersachsen/">
          <span>Niedersachsen</span>
          Hochzeit in Scheeßel
        </a>
        <a href="/gallery/traumhochzeit-in-hamburg/">
          <span>Hotel Atlantic</span>
          Traumhochzeit in Hamburg
        </a>
        <a href="/portfolio/">
          <span>Portfolio</span>
          Weitere Hochzeiten und Paarshootings
        </a>
      </nav>
    </article>
  </main>

  <footer class="gallery-footer">
    <a class="gallery-logo" href="/" aria-label="Artbild-Fotografie Startseite">
      <img src="/images/logo-artbild-black.png" width="1200" height="480" alt="Artbild Fotografie">
    </a>
    <nav aria-label="Footer">
      <a href="/kontakt/">Kontakt</a>
      <a href="/blog/">Blog</a>
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutz/">Datenschutzerklärung</a>
    </nav>
    <p>Copyright York Augustin. Alle Rechte vorbehalten.</p>
  </footer>
</body>
</html>

<style>
  .steffi-gallery {
    padding-top: clamp(74px, 7.4vw, 104px);
  }

  .steffi-hero {
    width: min(1050px, calc(100% - 44px));
    margin: 0 auto;
    text-align: center;
  }

  .steffi-hero__script {
    margin: 0;
    color: #30333b;
    font-family: "Bestermind", "Playfair Display", Georgia, serif;
    font-size: clamp(38px, 4.8vw, 66px);
    line-height: 1;
  }

  .steffi-hero__kicker,
  .steffi-story__heading p,
  .steffi-service__kicker {
    color: #846b58;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
  }

  .steffi-hero__kicker {
    margin: clamp(72px, 7vw, 98px) 0 0;
  }

  .steffi-hero h1 {
    margin: 20px 0 0;
    color: #282b34;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(44px, 5.5vw, 78px);
    font-weight: 400;
    line-height: 1.08;
  }

  .steffi-hero > p:last-child {
    width: min(780px, 100%);
    margin: 30px auto 0;
    color: #69635e;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(18px, 1.5vw, 22px);
    line-height: 1.68;
  }

  .steffi-story {
    width: min(1220px, calc(100% - 92px));
    margin: clamp(92px, 9vw, 138px) auto 0;
    padding: clamp(68px, 7vw, 102px) clamp(34px, 6vw, 86px);
    background: #f3f1ed;
  }

  .steffi-story__heading {
    width: min(820px, 100%);
  }

  .steffi-story__heading p,
  .steffi-service__kicker {
    margin: 0;
  }

  .steffi-story h2,
  .steffi-service h2 {
    margin: 20px 0 0;
    color: #292c35;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(34px, 4.2vw, 58px);
    font-weight: 400;
    line-height: 1.15;
  }

  .steffi-story__copy {
    margin-top: clamp(50px, 6vw, 78px);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(30px, 4vw, 60px);
  }

  .steffi-story h3 {
    margin: 0 0 18px;
    color: #292c35;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(23px, 2.2vw, 31px);
    font-weight: 400;
    line-height: 1.2;
  }

  .steffi-story__copy p,
  .steffi-service > div:last-child > p {
    margin: 0;
    color: #69635e;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(17px, 1.35vw, 20px);
    line-height: 1.7;
  }

  .steffi-meta {
    width: min(1170px, calc(100% - 48px));
    margin: 46px auto 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 20px;
    padding-top: 24px;
    border-top: 1px solid #dedad4;
    color: #706b65;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  .steffi-meta a {
    color: #2f323c;
    text-decoration: none;
  }

  .steffi-service {
    width: min(1110px, calc(100% - 48px));
    margin: clamp(100px, 10vw, 150px) auto;
    display: grid;
    grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr);
    gap: clamp(46px, 8vw, 110px);
    align-items: start;
  }

  .steffi-service > div:last-child {
    padding-top: 8px;
  }

  .steffi-service > div:last-child > p + p {
    margin-top: 22px;
  }

  .steffi-service__actions {
    margin-top: 38px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .steffi-service__actions a {
    min-height: 50px;
    padding: 0 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #2c3039;
    color: #2c3039;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .16em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .steffi-service__actions a.is-primary {
    background: #2c3039;
    color: #fff;
  }

  .steffi-related {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto clamp(100px, 10vw, 150px);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-block: 1px solid #dedad4;
  }

  .steffi-related a {
    min-height: 180px;
    padding: 34px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #292c35;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(20px, 2vw, 27px);
    line-height: 1.3;
    text-align: center;
    text-decoration: none;
  }

  .steffi-related a + a {
    border-left: 1px solid #dedad4;
  }

  .steffi-related span {
    margin-bottom: 14px;
    color: #846b58;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .steffi-related a:hover,
  .steffi-related a:focus-visible {
    background: #f3f1ed;
  }

  .steffi-meta a:focus-visible,
  .steffi-service a:focus-visible,
  .steffi-related a:focus-visible {
    outline: 2px solid #846b58;
    outline-offset: 4px;
  }

  @media (max-width: 880px) {
    .steffi-story__copy,
    .steffi-service {
      grid-template-columns: 1fr;
    }

    .steffi-story__copy div,
    .steffi-service > div {
      max-width: 690px;
    }
  }

  @media (max-width: 620px) {
    .steffi-gallery {
      padding-top: 48px;
    }

    .steffi-hero {
      width: min(100% - 28px, 520px);
    }

    .steffi-hero__kicker {
      margin-top: 60px;
    }

    .steffi-story {
      width: min(100% - 24px, 560px);
      margin-top: 72px;
      padding: 54px 22px;
    }

    .steffi-meta,
    .steffi-service,
    .steffi-related {
      width: min(100% - 28px, 560px);
    }

    .steffi-service__actions {
      align-items: stretch;
      flex-direction: column;
    }

    .steffi-related {
      grid-template-columns: 1fr;
    }

    .steffi-related a {
      min-height: 138px;
    }

    .steffi-related a + a {
      border-top: 1px solid #dedad4;
      border-left: 0;
    }
  }
</style>
