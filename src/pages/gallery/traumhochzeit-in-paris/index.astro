---
import "../../../styles/global.css";
import MobileNavigation from "../../../components/MobileNavigation.astro";
import GalleryImageGrid from "../../../components/GalleryImageGrid.astro";

const imageModules = import.meta.glob(
  "../../../assets/traumhochzeit-paris/*.jpg",
  { eager: true, import: "default" },
) as Record<string, ImageMetadata>;

const siteUrl = "https://artbild-fotografie.de";
const pagePath = "/gallery/traumhochzeit-in-paris/";
const pageUrl = `${siteUrl}${pagePath}`;
const heading = "Traumhochzeit in Paris";
const title = "Traumhochzeit in Paris | Hochzeitsfotografie Artbild-Fotografie";
const description =
  "Editoriale Hochzeitsfotografie in Paris: Brautportrait, Destination Wedding Inspiration und moderne Hochzeitsbilder mit französischem Stadtgefühl.";
const logoUrl = `${siteUrl}/images/logo-artbild-black.png`;

const altByFile: Record<string, string> = {
  "paris_braut_fotoshooting-17.jpg":
    "Braut in kurzem Kleid bei einem editorialen Hochzeitsfotoshooting in Paris",
  "paris_braut_fotoshooting-25.jpg":
    "Lachende Braut vor dem Eiffelturm bei einer Traumhochzeit in Paris",
  "paris_braut_fotoshooting-16.jpg":
    "Braut mit kurzem Hochzeitskleid in einer Pariser Straßenszene",
  "paris_braut_fotoshooting-31.jpg":
    "Elegantes Brautportrait bei einem Destination Wedding Shooting in Paris",
};

const modulesByFile = Object.fromEntries(
  Object.entries(imageModules).map(([path, image]) => [
    path.split("/").pop() ?? path,
    image,
  ]),
) as Record<string, ImageMetadata>;

const galleryImages = Object.entries(altByFile).map(([file, alt], index) => ({
  id: file.replace(/\.jpg$/, ""),
  image: modulesByFile[file],
  alt,
  aspect: "portrait" as const,
  eager: index === 0,
}));

const galleryColumns = [[], [], []] as typeof galleryImages[];
galleryImages.forEach((item, index) => galleryColumns[index % galleryColumns.length].push(item));

const primaryImage = new URL(galleryImages[0].image.src, siteUrl).href;
const parisPlace = {
  "@type": "City",
  "@id": `${pageUrl}#paris`,
  name: "Paris",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Paris",
    addressCountry: "FR",
  },
  containedInPlace: {
    "@type": "Country",
    name: "Frankreich",
  },
};

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${pageUrl}#article`,
      headline: heading,
      name: title,
      description,
      keywords: [
        "Traumhochzeit Paris",
        "Destination Wedding Paris",
        "Hochzeitsfotografie Paris",
        "Braut Fotoshooting Paris",
        "Hochzeitsfotograf Hamburg Destination Wedding",
      ],
      datePublished: "2019-07-05T12:52:02+02:00",
      dateModified: "2026-06-25T17:55:00+02:00",
      author: {
        "@type": "Person",
        name: "York Augustin",
      },
      publisher: {
        "@id": `${siteUrl}/#organization`,
      },
      image: primaryImage,
      mainEntityOfPage: {
        "@id": `${pageUrl}#webpage`,
      },
      contentLocation: {
        "@id": `${pageUrl}#paris`,
      },
      inLanguage: "de",
    },
    {
      "@type": "ImageGallery",
      "@id": `${pageUrl}#gallery`,
      name: "Traumhochzeit in Paris",
      description,
      contentLocation: {
        "@id": `${pageUrl}#paris`,
      },
      image: galleryImages.map((item, index) => ({
        "@type": "ImageObject",
        position: index + 1,
        caption: item.alt,
        contentUrl: new URL(item.image.src, siteUrl).href,
        width: item.image.width,
        height: item.image.height,
      })),
    },
    parisPlace,
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#organization`,
      name: "Artbild-Fotografie",
      url: siteUrl,
      email: "info@artbild-fotografie.de",
      logo: {
        "@type": "ImageObject",
        url: logoUrl,
      },
      address: {
        "@type": "PostalAddress",
        streetAddress: "Rahlstedter Bahnhofstraße 27",
        postalCode: "22143",
        addressLocality: "Hamburg",
        addressRegion: "Hamburg",
        addressCountry: "DE",
      },
      areaServed: [
        { "@type": "City", name: "Hamburg" },
        { "@type": "City", name: "Paris" },
        { "@type": "Country", name: "Frankreich" },
        { "@type": "AdministrativeArea", name: "Europa" },
      ],
      serviceType: [
        "Hochzeitsfotografie",
        "Destination Wedding Fotografie",
        "Editoriales Brautshooting",
        "Brautportrait",
      ],
      sameAs: [
        "https://www.instagram.com/artbild/",
        "https://www.facebook.com/artbildfotografie/",
        "https://www.pinterest.de/artbildf/",
      ],
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Startseite",
          item: siteUrl,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Portfolio",
          item: `${siteUrl}/portfolio/`,
        },
        {
          "@type": "ListItem",
          position: 3,
          name: heading,
          item: pageUrl,
        },
      ],
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: title,
      description,
      datePublished: "2019-07-05T12:52:02+02:00",
      dateModified: "2026-06-25T17:55:00+02:00",
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: primaryImage,
        caption: "Braut bei einem editorialen Hochzeitsfotoshooting in Paris",
      },
      breadcrumb: {
        "@id": `${pageUrl}#breadcrumb`,
      },
      inLanguage: "de",
    },
  ],
};
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large">
  <link rel="canonical" href={pageUrl}>
  <meta property="og:locale" content="de_DE">
  <meta property="og:type" content="article">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={pageUrl}>
  <meta property="og:site_name" content="Artbild-Fotografie">
  <meta property="article:published_time" content="2019-07-05T12:52:02+02:00">
  <meta property="article:modified_time" content="2026-06-25T17:55:00+02:00">
  <meta property="og:image" content={primaryImage}>
  <meta property="og:image:width" content={galleryImages[0].image.width}>
  <meta property="og:image:height" content={galleryImages[0].image.height}>
  <meta property="og:image:alt" content={galleryImages[0].alt}>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={primaryImage}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)}></script>
</head>
<body class="gallery-template paris-gallery-page">
  <header class="gallery-header">
    <MobileNavigation />
    <nav class="gallery-nav" aria-label="Hauptnavigation">
      <ul class="gallery-nav__group">
        <li><a href="/">Start</a></li>
        <li><a href="/portfolio/">Portfolio</a></li>
        <li><a href="/kontakt/">Kontakt</a></li>
      </ul>
      <a class="gallery-logo" href="/" aria-label="Artbild-Fotografie Startseite">
        <img src="/images/logo-artbild-black.png" width="1200" height="480" alt="Artbild Fotografie">
      </a>
      <ul class="gallery-nav__group">
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/about/">Über mich</a></li>
        <li><a href="/newsletter/">Newsletter</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <article class="paris-gallery">
      <header class="paris-hero">
        <p class="paris-hero__script" aria-hidden="true">Paris</p>
        <p class="paris-hero__kicker">Destination Wedding · Frankreich</p>
        <h1>{heading}</h1>
        <p>
          Ein editoriales Brautshooting in Paris: leicht, modern und mit jener
          eleganten Stadtstimmung, die Hochzeitsbilder sofort nach Reise,
          Freiheit und großer Liebe aussehen lässt.
        </p>
      </header>

      <section class="paris-story" aria-labelledby="paris-story-title">
        <div class="paris-story__heading">
          <p>Editoriale Hochzeitsfotografie</p>
          <h2 id="paris-story-title">Brautportrait, Stadtraum und französische Leichtigkeit</h2>
        </div>
        <div class="paris-story__copy">
          <div>
            <h3>Destination Feeling</h3>
            <p>
              Paris eignet sich für Hochzeitsbilder, die nicht inszeniert
              wirken müssen. Straßen, Architektur und Licht erzählen bereits
              viel von der Atmosphäre einer Reise.
            </p>
          </div>
          <div>
            <h3>Editorialer Look</h3>
            <p>
              Kurze Kleider, klare Linien und natürliche Bewegung geben den
              Bildern eine moderne, magazinartige Ruhe statt klassischer
              Posen.
            </p>
          </div>
          <div>
            <h3>Für Paare aus Hamburg</h3>
            <p>
              Artbild-Fotografie begleitet Hochzeiten und Paarshootings in
              Hamburg und als Destination Wedding auch an europäischen Orten
              wie Paris.
            </p>
          </div>
        </div>
      </section>

      <GalleryImageGrid
        columns={galleryColumns}
        galleryId="traumhochzeit-paris"
        label="Traumhochzeit in Paris mit Brautportrait und Destination Wedding Bildern"
        dialogLabel="Traumhochzeit in Paris in Vollansicht"
      />

      <aside class="paris-meta" aria-label="Galeriethemen">
        <span>Themen:</span>
        <a href="/gallery-tag/paris/">Paris</a>
        <a href="/gallery-tag/destination-wedding/">Destination Wedding</a>
        <a href="/gallery-tag/braut/">Brautportrait</a>
        <a href="/gallery-tag/hochzeit/">Hochzeit</a>
      </aside>

      <section class="paris-service" aria-labelledby="paris-service-title">
        <div>
          <p class="paris-service__kicker">Hochzeitsfotografie unterwegs</p>
          <h2 id="paris-service-title">Destination Wedding mit klarer Planung</h2>
        </div>
        <div>
          <p>
            Für Hochzeiten außerhalb Hamburgs sind Zeitplan, Reisewege und
            Lichtfenster besonders wichtig. Die fotografische Begleitung wird
            deshalb vorab ruhig geplant, damit vor Ort Raum für echte Bilder
            bleibt.
          </p>
          <p>
            Ob Paris, Mallorca oder Norddeutschland: Entscheidend ist eine
            Bildsprache, die den Ort spürbar macht und trotzdem bei Euch bleibt.
          </p>
          <div class="paris-service__actions">
            <a href="/portfolio/">Weitere Galerien ansehen</a>
            <a class="is-primary" href="/kontakt/">Destination Wedding anfragen</a>
          </div>
        </div>
      </section>

      <nav class="paris-related" aria-label="Weitere Destination- und Hochzeitsgalerien">
        <a href="/gallery/paarshooting-mallorca/">
          <span>Mallorca</span>
          Paarshooting Mallorca
        </a>
        <a href="/brautpaar-in-zuerich/">
          <span>Zürich</span>
          Brautpaar in Zürich
        </a>
        <a href="/gallery/traumhochzeit-in-hamburg/">
          <span>Hamburg</span>
          Traumhochzeit in Hamburg
        </a>
      </nav>
    </article>
  </main>

  <footer class="gallery-footer">
    <a class="gallery-logo" href="/" aria-label="Artbild-Fotografie Startseite">
      <img src="/images/logo-artbild-black.png" width="1200" height="480" alt="Artbild Fotografie">
    </a>
    <nav aria-label="Footer">
      <a href="/kontakt/">Kontakt</a>
      <a href="/blog/">Blog</a>
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutz/">Datenschutzerklärung</a>
    </nav>
    <p>Copyright York Augustin. Alle Rechte vorbehalten.</p>
  </footer>
</body>
</html>

<style>
  .paris-gallery {
    padding-top: clamp(74px, 7.4vw, 104px);
  }

  .paris-hero {
    width: min(1050px, calc(100% - 44px));
    margin: 0 auto;
    text-align: center;
  }

  .paris-hero__script {
    margin: 0;
    color: #30333b;
    font-family: "Bestermind", "Playfair Display", Georgia, serif;
    font-size: clamp(46px, 6vw, 86px);
    line-height: 1;
  }

  .paris-hero__kicker,
  .paris-story__heading p,
  .paris-service__kicker {
    color: #8d6e5a;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
  }

  .paris-hero__kicker {
    margin: clamp(66px, 6.4vw, 94px) 0 0;
  }

  .paris-hero h1 {
    margin: 20px 0 0;
    color: #282b34;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(46px, 5.8vw, 82px);
    font-weight: 400;
    line-height: 1.08;
  }

  .paris-hero > p:last-child {
    width: min(780px, 100%);
    margin: 30px auto 0;
    color: #69635e;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(18px, 1.5vw, 22px);
    line-height: 1.68;
  }

  .paris-story {
    width: min(1220px, calc(100% - 92px));
    margin: clamp(92px, 9vw, 138px) auto 0;
    padding: clamp(68px, 7vw, 102px) clamp(34px, 6vw, 86px);
    background: #f4f0ed;
  }

  .paris-story__heading {
    width: min(820px, 100%);
  }

  .paris-story__heading p,
  .paris-service__kicker {
    margin: 0;
  }

  .paris-story h2,
  .paris-service h2 {
    margin: 20px 0 0;
    color: #292c35;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(34px, 4.2vw, 58px);
    font-weight: 400;
    line-height: 1.15;
  }

  .paris-story__copy {
    margin-top: clamp(50px, 6vw, 78px);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(30px, 4vw, 60px);
  }

  .paris-story h3 {
    margin: 0 0 18px;
    color: #292c35;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(23px, 2.2vw, 31px);
    font-weight: 400;
    line-height: 1.2;
  }

  .paris-story__copy p,
  .paris-service > div:last-child > p {
    margin: 0;
    color: #69635e;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(17px, 1.35vw, 20px);
    line-height: 1.7;
  }

  .paris-meta {
    width: min(1170px, calc(100% - 48px));
    margin: 46px auto 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 20px;
    padding-top: 24px;
    border-top: 1px solid #dedad4;
    color: #706b65;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  .paris-meta a {
    color: #2f323c;
    text-decoration: none;
  }

  .paris-service {
    width: min(1110px, calc(100% - 48px));
    margin: clamp(100px, 10vw, 150px) auto;
    display: grid;
    grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr);
    gap: clamp(46px, 8vw, 110px);
    align-items: start;
  }

  .paris-service > div:last-child {
    padding-top: 8px;
  }

  .paris-service > div:last-child > p + p {
    margin-top: 22px;
  }

  .paris-service__actions {
    margin-top: 38px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .paris-service__actions a {
    min-height: 50px;
    padding: 0 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #2c3039;
    color: #2c3039;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .16em;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
  }

  .paris-service__actions a.is-primary {
    background: #2c3039;
    color: #fff;
  }

  .paris-related {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto clamp(100px, 10vw, 150px);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-block: 1px solid #dedad4;
  }

  .paris-related a {
    min-height: 180px;
    padding: 34px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #292c35;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(20px, 2vw, 27px);
    line-height: 1.3;
    text-align: center;
    text-decoration: none;
  }

  .paris-related a + a {
    border-left: 1px solid #dedad4;
  }

  .paris-related span {
    margin-bottom: 14px;
    color: #8d6e5a;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .paris-related a:hover,
  .paris-related a:focus-visible {
    background: #f4f0ed;
  }

  .paris-meta a:focus-visible,
  .paris-service a:focus-visible,
  .paris-related a:focus-visible {
    outline: 2px solid #8d6e5a;
    outline-offset: 4px;
  }

  @media (max-width: 880px) {
    .paris-story__copy,
    .paris-service {
      grid-template-columns: 1fr;
    }

    .paris-story__copy div,
    .paris-service > div {
      max-width: 690px;
    }
  }

  @media (max-width: 620px) {
    .paris-gallery {
      padding-top: 48px;
    }

    .paris-hero {
      width: min(100% - 28px, 520px);
    }

    .paris-hero__kicker {
      margin-top: 54px;
    }

    .paris-story {
      width: min(100% - 24px, 560px);
      margin-top: 72px;
      padding: 54px 22px;
    }

    .paris-meta,
    .paris-service,
    .paris-related {
      width: min(100% - 28px, 560px);
    }

    .paris-service__actions {
      align-items: stretch;
      flex-direction: column;
    }

    .paris-related {
      grid-template-columns: 1fr;
    }

    .paris-related a {
      min-height: 138px;
    }

    .paris-related a + a {
      border-top: 1px solid #dedad4;
      border-left: 0;
    }
  }
</style>
