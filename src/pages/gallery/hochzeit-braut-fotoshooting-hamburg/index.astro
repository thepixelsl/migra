---
import "../../../styles/global.css";
import MobileNavigation from "../../../components/MobileNavigation.astro";
import GalleryImageGrid from "../../../components/GalleryImageGrid.astro";

const imageModules = import.meta.glob(
  "../../../assets/braut-fotoshooting-hamburg/*.jpg",
  { eager: true, import: "default" },
) as Record<string, ImageMetadata>;

const siteUrl = "https://artbild-fotografie.de";
const pagePath = "/gallery/hochzeit-braut-fotoshooting-hamburg/";
const pageUrl = `${siteUrl}${pagePath}`;
const heading = "Braut Fotoshooting Hamburg";
const title = "Braut Fotoshooting Hamburg im Hotel Atlantic | Artbild-Fotografie";
const description =
  "Editoriales Braut Fotoshooting und Getting Ready im Hotel Atlantic Hamburg: Brautkleider, Styling und zeitlose Hochzeitsfotografie an der Alster.";
const logoUrl = `${siteUrl}/images/logo-artbild-black.png`;

const altByFile: Record<string, string> = {
  "ART_8686-Bearbeitet-2-scaled.jpg": "Braut Marica mit Schleier beim Fotoshooting im Hotel Atlantic Hamburg",
  "ART_0005-scaled.jpg": "Elegantes Brautportrait im Hotelzimmer des Hotel Atlantic Hamburg",
  "ART_9987-Bearbeitet-scaled.jpg": "Braut in weißem Kleid auf dem Bett einer Hotelsuite in Hamburg",
  "ART_9546-Verbessert-RR-Bearbeitet-scaled.jpg": "Braut im modernen Hochzeitskleid bei einem Bridal Shooting in Hamburg",
  "ART_9290-Bearbeitet-scaled.jpg": "Klassisches Brautportrait mit rotem Lippenstift im Hotel Atlantic",
  "ART_8902-Bearbeitet-scaled.jpg": "Braut mit Perlenkette und Haarschmuck am Fenster einer Hamburger Suite",
  "ART_8855-Bearbeitet-scaled.jpg": "Nachdenkliche Braut im Spitzenkleid am Fenster des Hotel Atlantic",
  "ART_9808-scaled.jpg": "Braut mit Schleier beim editorialen Hochzeitsshooting in Hamburg",
  "ART_9664-scaled.jpg": "Brautkleid mit langer Schleppe in einer Suite des Hotel Atlantic",
  "ART_0011-Bearbeitet-scaled.jpg": "Portrait einer Braut mit elegantem Haarstyling und rotem Lippenstift",
  "ART_9644-Bearbeitet-scaled.jpg": "Braut im Hochzeitskleid vor der klassischen Tür einer Hotelsuite",
  "ART_9985-Bearbeitet-scaled.jpg": "Braut sitzt im weißen Kleid auf einem Hotelbett in Hamburg",
