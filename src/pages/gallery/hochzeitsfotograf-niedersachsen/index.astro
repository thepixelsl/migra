---
import "../../../styles/global.css";
import MobileNavigation from "../../../components/MobileNavigation.astro";
import GalleryImageGrid from "../../../components/GalleryImageGrid.astro";

const imageModules = import.meta.glob(
  "../../../assets/hochzeitsfotograf-niedersachsen/*.jpg",
  { eager: true, import: "default" },
) as Record<string, ImageMetadata>;

const siteUrl = "https://artbild-fotografie.de";
const pagePath = "/gallery/hochzeitsfotograf-niedersachsen/";
const pageUrl = `${siteUrl}${pagePath}`;
const heading = "Hochzeitsfotograf Niedersachsen";
const title = "Hochzeitsfotograf Niedersachsen | Hochzeit in Scheeßel";
const description =
  "Hochzeitsreportage von Kathrin und Sven in Scheeßel und Lauenbrück: Getting Ready, standesamtliche Trauung und natürliches Brautpaarshooting in Niedersachsen.";
const logoUrl = `${siteUrl}/images/logo-artbild-black.png`;

const altByFile: Record<string, string> = {
  "Hochzeit_Lauenbrueck_3803-1024x684.jpg":
    "Herzdekoration im Grünen bei einer Hochzeit in Niedersachsen",
  "Hochzeit_Lauenbrueck_4738-1024x684.jpg":
    "Bräutigam Sven beim Portraitshooting vor der Trauung in Scheeßel",
  "Hochzeit_Lauenbrueck_4711-2-Bearbeitet-864x1536.jpg":
    "Brautkleid und Brautschuhe beim Getting Ready in Lauenbrück",
  "Hochzeit_Lauenbrueck_4903-2.jpg":
    "Braut Kathrin betrachtet sich nach dem Getting Ready im Spiegel",
  "Hochzeit_Lauenbrueck_4901-2.jpg":
    "Braut beim Anlegen des Schleiers vor der Hochzeit in Niedersachsen",
  "Hochzeit_Lauenbrueck_3907-1024x684.jpg":
    "Bräutigam wartet vor der standesamtlichen Trauung in Scheeßel",
  "Hochzeit_Lauenbrueck_5817-1024x682.jpg":
    "Standesamtliche Trauung von Kathrin und Sven in Niedersachsen",
  "Hochzeit_Lauenbrueck_5771-1024x682.jpg":
    "Ringtausch bei der standesamtlichen Hochzeit in Scheeßel",
  "Hochzeit_Lauenbrueck_5773-1024x682.jpg":
    "Kathrin und Sven beim Ringtausch im Standesamt",
  "Hochzeit_Lauenbrueck_5901-1024x819.jpg":
    "Brautpaar gibt sich das Eheversprechen im Standesamt Scheeßel",
  "Hochzeit_Lauenbrueck_5825-3-1024x682.jpg":
    "Lächelndes Brautpaar während der standesamtlichen Trauung",
  "Hochzeit_Lauenbrueck_5932-1024x819.jpg":
    "Kathrin und Sven nach dem Ja-Wort in Niedersachsen",
  "Hochzeit_Lauenbrueck_6049-1024x682.jpg":
    "Unterschrift des Brautpaares nach der Eheschließung",
  "Hochzeit_Lauenbrueck_6057-1024x819.jpg":
    "Bräutigam steckt der Braut den Ehering an",
  "Hochzeit_Lauenbrueck_5948-1024x682.jpg":
    "Erster Kuss des Brautpaares nach der standesamtlichen Trauung",
  "Hochzeit_Lauenbrueck_6262-1024x682.jpg":
    "Gratulation nach der Hochzeit von Kathrin und Sven",
  "Hochzeit_Lauenbrueck_4766-1.jpg":
    "Brautpaar vor einem Fachwerkhaus in Lauenbrück",
  "Hochzeit_Lauenbrueck_4794-1-1024x684.jpg":
    "Kuss des Brautpaares beim Hochzeitsshooting in Scheeßel",
  "Hochzeit_Lauenbrueck_4929-Bearbeitet-1024x684.jpg":
    "Kathrin und Sven mit Brautstrauß vor einem historischen Gebäude",
  "Hochzeit_Lauenbrueck_4580-2-1024x684.jpg":
    "Schwarz-Weiß-Portrait des Brautpaares in Niedersachsen",
  "Hochzeit_Lauenbrueck_7740.jpg":
    "Detailaufnahme der Eheringe beim Brautpaarshooting",
  "Hochzeit_Lauenbrueck_7480.jpg":
    "Brautpaar in einer weiten Parklandschaft in Niedersachsen",
  "Hochzeit_Lauenbrueck_6916-2-1024x682.jpg":
    "Schwarz-Weiß-Portrait des küssenden Brautpaares vor Holztüren",
  "Hochzeit_Lauenbrueck_6916-1024x682.jpg":
    "Brautpaar küsst sich vor grünen historischen Holztüren",
  "Hochzeit_Lauenbrueck_7587.jpg":
    "Fröhliches Brautpaar beim natürlichen Hochzeitsshooting",
  "Hochzeit_Lauenbrueck_7237-Bearbeitet-1024x682.jpg":
    "Kathrin und Sven vor einem niedersächsischen Fachwerkhaus",
};

const modulesByFile = Object.fromEntries(
  Object.entries(imageModules).map(([path, image]) => [
    path.split("/").pop() ?? path,
    image,
  ]),
) as Record<string, ImageMetadata>;

const galleryImages = Object.entries(altByFile).map(([file, alt], index) => ({
  id: file.replace(/\.jpg$/, ""),
  image: modulesByFile[file],
  alt,
  aspect: "natural" as const,
  eager: index === 0,
}));

const itemsPerColumn = Math.ceil(galleryImages.length / 3);
const galleryColumns = [
  galleryImages.slice(0, itemsPerColumn),
  galleryImages.slice(itemsPerColumn, itemsPerColumn * 2),
  galleryImages.slice(itemsPerColumn * 2),
];

const primaryImage = new URL(
  modulesByFile["Hochzeit_Lauenbrueck_4794-1-1024x684.jpg"].src,
  siteUrl,
).href;

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${pageUrl}#article`,
      headline: heading,
      name: title,
      description,
      keywords: [
        "Hochzeitsfotograf Niedersachsen",
        "Hochzeit Scheeßel",
        "Hochzeit Lauenbrück",
        "Standesamtliche Trauung Niedersachsen",
      ],
      datePublished: "2021-08-12T09:59:28+02:00",
      dateModified: "2026-06-24T23:00:00+02:00",
      author: {
        "@type": "Person",
        name: "York Augustin",
      },
      publisher: {
        "@id": `${siteUrl}/#organization`,
      },
      image: primaryImage,
      mainEntityOfPage: {
        "@id": `${pageUrl}#webpage`,
      },
      contentLocation: [
        { "@id": `${pageUrl}#scheessel` },
        { "@id": `${pageUrl}#lauenbrueck` },
      ],
      inLanguage: "de",
    },
    {
      "@type": "ImageGallery",
      "@id": `${pageUrl}#gallery`,
      name: "Hochzeit von Kathrin und Sven in Niedersachsen",
      description,
      contentLocation: [
        { "@id": `${pageUrl}#scheessel` },
        { "@id": `${pageUrl}#lauenbrueck` },
      ],
      image: galleryImages.map((item, index) => ({
        "@type": "ImageObject",
        position: index + 1,
        caption: item.alt,
        contentUrl: new URL(item.image.src, siteUrl).href,
        width: item.image.width,
        height: item.image.height,
      })),
    },
    {
      "@type": "Place",
      "@id": `${pageUrl}#scheessel`,
      name: "Scheeßel",
      address: {
        "@type": "PostalAddress",
        postalCode: "27383",
        addressLocality: "Scheeßel",
        addressRegion: "Niedersachsen",
        addressCountry: "DE",
      },
    },
    {
      "@type": "Place",
      "@id": `${pageUrl}#lauenbrueck`,
      name: "Lauenbrück",
      address: {
        "@type": "PostalAddress",
        postalCode: "27389",
        addressLocality: "Lauenbrück",
        addressRegion: "Niedersachsen",
        addressCountry: "DE",
      },
    },
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#organization`,
      name: "Artbild-Fotografie",
      url: siteUrl,
      email: "info@artbild-fotografie.de",
      logo: {
        "@type": "ImageObject",
        url: logoUrl,
      },
      address: {
        "@type": "PostalAddress",
        streetAddress: "Rahlstedter Bahnhofstraße 27",
        postalCode: "22143",
        addressLocality: "Hamburg",
        addressRegion: "Hamburg",
        addressCountry: "DE",
      },
      areaServed: [
        { "@type": "State", name: "Niedersachsen" },
        { "@type": "City", name: "Hamburg" },
        { "@type": "AdministrativeArea", name: "Norddeutschland" },
      ],
      serviceType: [
        "Hochzeitsfotografie",
        "Standesamtliche Hochzeitsreportage",
        "Getting Ready Fotografie",
        "Brautpaarshooting",
      ],
      sameAs: [
        "https://www.instagram.com/artbild/",
        "https://www.facebook.com/artbildfotografie/",
        "https://www.pinterest.de/artbildf/",
      ],
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${pageUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Startseite",
          item: siteUrl,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Portfolio",
          item: `${siteUrl}/portfolio/`,
        },
        {
          "@type": "ListItem",
          position: 3,
          name: heading,
          item: pageUrl,
        },
      ],
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: title,
      description,
      datePublished: "2021-08-12T09:59:28+02:00",
      dateModified: "2026-06-24T23:00:00+02:00",
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: primaryImage,
        caption: "Kathrin und Sven bei ihrer Hochzeit in Niedersachsen",
      },
      breadcrumb: {
        "@id": `${pageUrl}#breadcrumb`,
      },
      inLanguage: "de",
    },
  ],
};
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large">
  <link rel="canonical" href={pageUrl}>
  <meta property="og:locale" content="de_DE">
  <meta property="og:type" content="article">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={pageUrl}>
  <meta property="og:site_name" content="Artbild-Fotografie">
  <meta property="article:published_time" content="2021-08-12T09:59:28+02:00">
  <meta property="article:modified_time" content="2026-06-24T23:00:00+02:00">
  <meta property="og:image" content={primaryImage}>
  <meta property="og:image:width" content={modulesByFile["Hochzeit_Lauenbrueck_4794-1-1024x684.jpg"].width}>
  <meta property="og:image:height" content={modulesByFile["Hochzeit_Lauenbrueck_4794-1-1024x684.jpg"].height}>
  <meta property="og:image:alt" content="Kathrin und Sven bei ihrer Hochzeit in Niedersachsen">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={primaryImage}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)}></script>
</head>
<body class="gallery-template lower-saxony-gallery-page">
  <header class="gallery-header">
    <MobileNavigation />
    <nav class="gallery-nav" aria-label="Hauptnavigation">
      <ul class="gallery-nav__group">
        <li><a href="/">Start</a></li>
        <li><a href="/portfolio/">Portfolio</a></li>
        <li><a href="https://artbild-fotografie.de/kontakt/">Kontakt</a></li>
      </ul>
      <a class="gallery-logo" href="/" aria-label="Artbild-Fotografie Startseite">
        <img src="/images/logo-artbild-black.png" width="1200" height="480" alt="Artbild Fotografie">
      </a>
      <ul class="gallery-nav__group">
        <li><a href="https://artbild-fotografie.de/blog/">Blog</a></li>
        <li><a href="https://artbild-fotografie.de/about/">Über mich</a></li>
        <li><a href="https://artbild-fotografie.de/newsletter/">Newsletter</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <article class="lower-saxony-gallery">
      <header class="lower-saxony-hero">
        <p class="lower-saxony-hero__script" aria-hidden="true">Kathrin & Sven</p>
        <p class="lower-saxony-hero__kicker">Hochzeitsreportage · Scheeßel & Lauenbrück</p>
        <h1>{heading}</h1>
        <p>
          Vom Getting Ready über die standesamtliche Trauung bis zum
          Brautpaarshooting durfte ich Kathrin und Sven an ihrem Hochzeitstag
          im niedersächsischen Raum Scheeßel begleiten.
        </p>
      </header>

      <section class="lower-saxony-story" aria-labelledby="lower-saxony-story-title">
        <div class="lower-saxony-story__heading">
          <p>Eine Hochzeit in Norddeutschland</p>
          <h2 id="lower-saxony-story-title">Persönliche Momente zwischen Fachwerk und Natur</h2>
        </div>
        <div class="lower-saxony-story__copy">
          <div>
            <h3>Getting Ready</h3>
            <p>
              Die Reportage beginnt mit den ruhigen Vorbereitungen von Braut und
              Bräutigam. Kleid, Schuhe, Schleier und die ersten Portraits geben
              diesem Teil des Tages eine persönliche, erwartungsvolle Stimmung.
            </p>
          </div>
          <div>
            <h3>Standesamtliche Trauung</h3>
            <p>
              Im Kreis ihrer Familie und Freunde gaben sich Kathrin und Sven
              das Ja-Wort. Ringtausch, Unterschrift, Kuss und Gratulationen
              erzählen die Trauung als zusammenhängende Hochzeitsreportage.
            </p>
          </div>
          <div>
            <h3>Brautpaarshooting</h3>
            <p>
              Fachwerk, historische Holztüren und die weite Landschaft rund um
              Scheeßel und Lauenbrück bilden den natürlichen Rahmen für
              zeitlose Paarbilder ohne starre Inszenierung.
            </p>
          </div>
        </div>
      </section>

      <GalleryImageGrid
        columns={galleryColumns}
        galleryId="hochzeitsfotograf-niedersachsen"
        label="Hochzeitsreportage von Kathrin und Sven in Niedersachsen"
        dialogLabel="Hochzeit in Niedersachsen in Vollansicht"
      />

      <aside class="lower-saxony-meta" aria-label="Galeriethemen">
        <span>Themen:</span>
        <a href="https://artbild-fotografie.de/gallery-tag/hochzeit/">Hochzeit</a>
        <a href="https://artbild-fotografie.de/gallery-tag/hochzeitsfotograf/">Hochzeitsfotograf</a>
        <a href="https://artbild-fotografie.de/gallery-tag/braut/">Braut</a>
        <a href="https://artbild-fotografie.de/gallery-tag/braeutigam/">Bräutigam</a>
      </aside>

      <section class="lower-saxony-service" aria-labelledby="lower-saxony-service-title">
        <div>
          <p class="lower-saxony-service__kicker">Planbare Leistungen</p>
          <h2 id="lower-saxony-service-title">Bildbearbeitung ohne versteckte Zusatzkosten</h2>
        </div>
        <div>
          <p>
            Bei Artbild-Fotografie ist die Bearbeitung aller gelieferten Bilder
            bereits im vereinbarten Preis enthalten. So müsst Ihr nicht nach
            der Hochzeit entscheiden, welcher persönliche Moment eine
            zusätzliche Bearbeitung wert ist.
          </p>
          <p>
            Ihr erhaltet eine stimmige Reportage, in der auch die leisen
            Augenblicke ihren Platz behalten. Leistungen und Umfang werden vor
            der Buchung transparent besprochen.
          </p>
          <div class="lower-saxony-service__actions">
            <a href="https://artbild-fotografie.de/hochzeitsfotograf-preise/">Preise & Pakete ansehen</a>
            <a class="is-primary" href="https://artbild-fotografie.de/kontakt/">Hochzeit anfragen</a>
          </div>
        </div>
      </section>

      <nav class="lower-saxony-related" aria-label="Weitere Hochzeitsreportagen">
        <a href="/gallery/standesamtliche-trauung-standesamt-altona-hochzeitsfotograf-hamburg/">
          <span>Hamburg-Altona</span>
          Standesamtliche Trauung
        </a>
        <a href="/gallery/hochzeit-braut-fotoshooting-hamburg/">
          <span>Getting Ready</span>
          Braut Fotoshooting Hamburg
        </a>
        <a href="/portfolio/">
          <span>Portfolio</span>
          Weitere Hochzeiten und Paarshootings
        </a>
      </nav>
    </article>
  </main>

  <footer class="gallery-footer">
    <a class="gallery-logo" href="/" aria-label="Artbild-Fotografie Startseite">
      <img src="/images/logo-artbild-black.png" width="1200" height="480" alt="Artbild Fotografie">
    </a>
    <nav aria-label="Footer">
      <a href="https://artbild-fotografie.de/kontakt/">Kontakt</a>
      <a href="https://artbild-fotografie.de/blog/">Blog</a>
      <a href="/impressum/">Impressum</a>
      <a href="https://artbild-fotografie.de/datenschutz/">Datenschutzerklärung</a>
    </nav>
    <p>Copyright York Augustin. Alle Rechte vorbehalten.</p>
  </footer>
</body>
</html>

<style>
  .lower-saxony-gallery {
    padding-top: clamp(74px, 7.4vw, 104px);
  }

  .lower-saxony-hero {
    width: min(1050px, calc(100% - 44px));
    margin: 0 auto;
    text-align: center;
  }

  .lower-saxony-hero__script {
    margin: 0;
    color: #30333b;
    font-family: "Bestermind", "Playfair Display", Georgia, serif;
    font-size: clamp(36px, 4.5vw, 62px);
    line-height: 1;
  }

  .lower-saxony-hero__kicker,
  .lower-saxony-story__heading p,
  .lower-saxony-service__kicker {
    color: #846b58;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
  }

  .lower-saxony-hero__kicker {
    margin: clamp(72px, 7vw, 98px) 0 0;
  }

  .lower-saxony-hero h1 {
    margin: 20px 0 0;
    color: #282b34;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(42px, 5.3vw, 74px);
    font-weight: 400;
    line-height: 1.08;
  }

  .lower-saxony-hero > p:last-child {
    width: min(780px, 100%);
    margin: 30px auto 0;
    color: #69635e;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(18px, 1.5vw, 22px);
    line-height: 1.68;
  }

  .lower-saxony-story {
    width: min(1220px, calc(100% - 92px));
    margin: clamp(92px, 9vw, 138px) auto 0;
    padding: clamp(68px, 7vw, 102px) clamp(34px, 6vw, 86px);
    background: #f3f1ed;
  }

  .lower-saxony-story__heading {
    width: min(800px, 100%);
  }

  .lower-saxony-story__heading p,
  .lower-saxony-service__kicker {
    margin: 0;
  }

  .lower-saxony-story h2,
  .lower-saxony-service h2 {
    margin: 20px 0 0;
    color: #292c35;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(34px, 4.2vw, 58px);
    font-weight: 400;
    line-height: 1.15;
  }

  .lower-saxony-story__copy {
    margin-top: clamp(50px, 6vw, 78px);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(30px, 4vw, 60px);
  }

  .lower-saxony-story h3 {
    margin: 0 0 18px;
    color: #292c35;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(23px, 2.2vw, 31px);
    font-weight: 400;
    line-height: 1.2;
  }

  .lower-saxony-story__copy p,
  .lower-saxony-service > div:last-child > p {
    margin: 0;
    color: #69635e;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(17px, 1.35vw, 20px);
    line-height: 1.7;
  }

  .lower-saxony-meta {
    width: min(1170px, calc(100% - 48px));
    margin: 46px auto 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 20px;
    padding-top: 24px;
    border-top: 1px solid #dedad4;
    color: #706b65;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  .lower-saxony-meta a {
    color: #2f323c;
    text-decoration: none;
  }

  .lower-saxony-service {
    width: min(1110px, calc(100% - 48px));
    margin: clamp(100px, 10vw, 150px) auto;
    display: grid;
    grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr);
    gap: clamp(46px, 8vw, 110px);
    align-items: start;
  }

  .lower-saxony-service > div:last-child {
    padding-top: 8px;
  }

  .lower-saxony-service > div:last-child > p + p {
    margin-top: 22px;
  }

  .lower-saxony-service__actions {
    margin-top: 38px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .lower-saxony-service__actions a {
    min-height: 50px;
    padding: 0 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #2c3039;
    color: #2c3039;
    font-family: "Raleway", Arial, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .16em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .lower-saxony-service__actions a.is-primary {
    background: #2c3039;
    color: #fff;
  }

  .lower-saxony-related {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto clamp(100px, 10vw, 150px);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-block: 1px solid #dedad4;
  }

  .lower-saxony-related a {
    min-height: 180px;
    padding: 34px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #292c35;
    font-family: "Gilda Display", "Playfair Display", Georgia, serif;
    font-size: clamp(20px, 2vw, 27px);
    line-height: 1.3;
    text-align: center;
    text-decoration: none;
  }

  .lower-saxony-related a + a {
    border-left: 1px solid #dedad4;
  }

  .lower-saxony-related span {
    margin-bottom: 14px;
    color: #846b58;
    font-family: "Raleway", Arial, sans-serif;
