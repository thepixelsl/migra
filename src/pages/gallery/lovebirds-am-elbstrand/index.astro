import art8380 from "../../../assets/lovebirds-am-elbstrand/art-8380.jpg";
import art8360 from "../../../assets/lovebirds-am-elbstrand/art-8360.jpg";
import art8239 from "../../../assets/lovebirds-am-elbstrand/art-8239.jpg";
