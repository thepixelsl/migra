                  <Image
                    src={item.image}
                    alt={item.alt}
                    widths={[360, 620, 920, 1200]}
                    sizes="(max-width: 700px) 100vw, (max-width: 1100px) 45vw, 31vw"
                    loading="lazy"
                    decoding="async"
                  />
                </button>
              </figure>
            ))}
