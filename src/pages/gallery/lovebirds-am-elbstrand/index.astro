            <img data-gallery-image alt="">
            <figcaption data-gallery-caption></figcaption>
          </figure>
          <button class="lovebirds-lightbox__nav is-next" type="button" data-gallery-next aria-label="Nächstes Bild">›</button>
        </div>
      </div>

      <aside class="lovebirds-share" aria-label="Artikel teilen und Schlagworte">
