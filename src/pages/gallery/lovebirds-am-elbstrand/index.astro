  { id: "art-8381", image: art8381, alt: "Paarshooting in Hamburg in ruhigem Licht", aspect: "landscape" },
  { id: "art-8080", image: art8080, alt: "Paarshooting am Elbstrand in ruhiger Nähe", aspect: "wide" },
  { id: "art-8385", image: art8385, alt: "Natürliches Verlobungsshooting am Wasser", aspect: "landscape" },
  { id: "art-8380", image: art8380, alt: "Brautpaar vor der Hochzeit beim Kennenlernshooting", aspect: "landscape" },
  { id: "art-8360", image: art8360, alt: "Paarfoto am Hamburger Elbstrand", aspect: "landscape" },
  { id: "art-8239", image: art8239, alt: "Hochformat Portrait eines Paares am Elbstrand", aspect: "portrait" },
  { id: "art-8208", image: art8208, alt: "Verlobungsshooting mit natürlicher Bewegung", aspect: "landscape" },
  { id: "art-8065", image: art8065, alt: "Paarshooting in Hamburg vor der Hochzeit", aspect: "landscape" },
  { id: "art-7696", image: art7696, alt: "Kennenlernshooting eines Paares am Elbstrand", aspect: "landscape" },
  { id: "art-7981", image: art7981, alt: "Elegantes Paarportrait am Wasser", aspect: "landscape" },
  { id: "art-7547", image: art7547, alt: "Lovebirds am Hamburger Elbstrand", aspect: "landscape" },
  { id: "art-7943", image: art7943, alt: "Hochzeitsfotograf begleitet ein Paarshooting in Hamburg", aspect: "landscape" },
  { id: "art-7786", image: art7786, alt: "Verlobungsshooting mit Blick auf die Elbe", aspect: "landscape" },
  { id: "art-7859", image: art7859, alt: "Natürliches Paarfoto am Elbstrand", aspect: "landscape" },
];

const galleryColumns = [
  ["art-8413", "art-8249", "art-8239", "art-7943"],
  ["art-8273", "art-8381", "art-8385", "art-8360", "art-8065", "art-7981", "art-7786"],
  ["art-8407", "art-8080", "art-8380", "art-8208", "art-7696", "art-7547", "art-7859"],
].map((column) => column.map((id) => galleryImages.find((item) => item.id === id)).filter(Boolean));

